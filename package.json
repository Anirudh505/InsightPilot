{
  "name": "insightpilot-monorepo",
  "version": "1.0.0",
  "description": "InsightPilot - AI Product Analytics SaaS Platform",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "sdk"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "npm run dev:server & npm run dev:client",
    "build:client": "npm run build --workspace=client",
    "build:sdk": "npm run build --workspace=sdk",
    "build": "npm run build:client && npm run build:sdk",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "npm run test --workspaces",
    "clean": "rm -rf node_modules client/node_modules server/node_modules sdk/node_modules"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}
