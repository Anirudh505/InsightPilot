# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Connection String (Paste your MongoDB Atlas cluster string here)
MONGODB_URI=mongodb://localhost:27017/insightpilot

# Frontend URL (For CORS - Use your Vercel URL in production)
CLIENT_URL=http://localhost:3000

# Authentication Secrets (Generate secure random strings for these)
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (Optional but recommended for caching)
REDIS_URL=redis://localhost:6379

# Email Configuration (For invites and notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# External APIs
OPENAI_API_KEY=your_openai_api_key
CLOUDINARY_URL=your_cloudinary_url
